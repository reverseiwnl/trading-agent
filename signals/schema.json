{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DailySignals",
  "type": "object",
  "required": ["date", "signals", "market_context"],
  "additionalProperties": false,
  "properties": {
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "market_context": { "type": "string", "maxLength": 1000 },
    "signals": {
      "type": "array",
      "maxItems": 25,
      "items": {
        "type": "object",
        "required": ["ticker", "action", "conviction", "thesis", "sources", "timestamp"],
        "additionalProperties": false,
        "properties": {
          "ticker": { "type": "string", "pattern": "^[A-Z]{1,5}$" },
          "action": { "type": "string", "enum": ["buy", "sell", "hold"] },
          "conviction": { "type": "number", "minimum": 0, "maximum": 1 },
          "thesis": { "type": "string", "minLength": 20, "maxLength": 500 },
          "sources": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "timestamp": { "type": "string" }
        }
      }
    }
  }
}
